<script>
// ═══════════════════════════════════════
//  STATE
// ═══════════════════════════════════════
let batches = [];       // [{id, name, date, orders:[]}]
// costMap: productName → {costPrice: 원가, extraCost: 기타비용}
let costMap = {};
let checkedIds = {};
let poCheckedIds = {}; // 하위호환용 (사용 안 함)
let poQtyMap = {};     // "상품명__옵션" → 입력한 발주 수량
// shippingMap: productName → { itemName: '가방', unitPrice: 50000 }
let shippingMap = {};
let charts = {};

function allOrders(){ return batches.flatMap(b=>b.orders); }

// 취소 완료 · 반품 접수는 매출/순이익 집계에서 제외
const EXCLUDED = new Set(['취소 완료','취소완료','반품 접수','반품접수','반품 완료','반품완료']);
function activeOrders(){ return allOrders().filter(o=>!EXCLUDED.has(o.status)); }

// ═══════════════════════════════════════
//  LOCALSTORAGE 자동저장
// ═══════════════════════════════════════
const LS_KEY = 'ably_dash_v3';
let saveTimer = null;

function saveToStorage(){
  try {
    const data = { batches, costMap, checkedIds, poCheckedIds, poQtyMap, shippingMap };
    localStorage.setItem(LS_KEY, JSON.stringify(data));
    const el = document.getElementById('saveIndicator');
    el.textContent = '저장됨 ✓';
    el.className = 'save-indicator saving';
    setTimeout(()=>{ el.textContent='자동 저장됨'; el.className='save-indicator'; }, 2000);
  } catch(e){ console.warn('저장 실패(용량 초과 가능성):', e); }
}

function loadFromStorage(){
  try {
    const raw = localStorage.getItem(LS_KEY);
    if (!raw) return false;
    const data = JSON.parse(raw);
    batches    = data.batches    || [];
    costMap    = data.costMap    || {};
    checkedIds   = data.checkedIds   || {};
    poCheckedIds = data.poCheckedIds || {};
    poQtyMap     = data.poQtyMap     || {};
    shippingMap  = data.shippingMap  || {};
    return batches.length > 0;
  } catch(e){ return false; }
}

function scheduleSave(){
  clearTimeout(saveTimer);
  saveTimer = setTimeout(saveToStorage, 600);
}

// ═══════════════════════════════════════
//  NAV
// ═══════════════════════════════════════
const pageMeta = {
  dashboard:{title:'대시보드',sub:'전체 매출 현황'},
  orders:{title:'주문 목록',sub:'전체 주문 검색 및 관리'},
  compare:{title:'매출 vs 순이익',sub:'결제액 기준 실제 수익 비교'},
  products:{title:'상품별 분석',sub:'상품별 결제액 및 순이익 순위'},
  margin:{title:'원가 · 마진 설정',sub:'상품별 매입가 · 기타비용 직접 입력'},
  checklist:{title:'발송 체크리스트',sub:'상품 준비중 주문 발송 관리'},
  'order-mgmt':{title:'발주 관리',sub:'발송 대기 주문 기준 · 상품/옵션별 사입 체크리스트'},
  batches:{title:'업로드 관리',sub:'업로드 배치별 삭제'},
};
function go(tab, el){
  document.querySelectorAll('.tab-content').forEach(t=>t.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  document.querySelectorAll('.nav-item').forEach(n=>n.classList.remove('active'));
  el.classList.add('active');
  document.getElementById('pageTitle').textContent = pageMeta[tab].title;
  document.getElementById('pageSub').textContent   = pageMeta[tab].sub;
  if(allOrders().length){
    if(tab==='dashboard')   renderDashboard();
    if(tab==='orders')      renderOrders();
    if(tab==='compare')     renderCompare();
    if(tab==='products')    renderProducts();
    if(tab==='margin')      renderMargin();
    if(tab==='checklist')   renderChecklist();
    if(tab==='order-mgmt')  renderOrderMgmt();
    if(tab==='batches')     renderBatches();
  } else if(tab==='batches') renderBatches();
}

// ═══════════════════════════════════════
//  MODAL
// ═══════════════════════════════════════
function openModal(){ document.getElementById('importModal').classList.add('open'); }
function closeModal(){ document.getElementById('importModal').classList.remove('open'); }
document.getElementById('importModal').addEventListener('click', e=>{ if(e.target===e.currentTarget) closeModal(); });

// ═══════════════════════════════════════
//  PARSE
// ═══════════════════════════════════════
function findCol(header, keywords){
  for(let kw of keywords){
    const i = header.findIndex(h=>h&&h.trim().includes(kw));
    if(i>=0) return i;
  }
  return -1;
}
function gc(row,i,def=''){ return (i>=0&&row[i]!==undefined)?row[i].trim():def; }
function pn(s){ return parseFloat((s||'').replace(/[,₩\s원]/g,''))||0; }
function fmt(n){ return '₩'+Math.round(n).toLocaleString(); }
function fmtPct(n){ return n.toFixed(1)+'%'; }

function parseData(){
  const raw = document.getElementById('pasteArea').value.trim();
  if(!raw){ document.getElementById('parseMsg').textContent='데이터를 붙여넣어 주세요.'; return; }
  const rows  = raw.split('\n').map(r=>r.split('\t'));
  const header= rows[0];
  const hasHeader = header.some(h=>h&&(h.includes('결제일')||h.includes('상품명')||h.includes('판매가')));
  let idx;
  if(hasHeader){
    idx={
      date:       findCol(header,['결제일','결재일']),
      name:       findCol(header,['상품명']),
      option:     findCol(header,['옵션 정보','옵션정보']),
      price:      findCol(header,['판매가']),
      qty:        findCol(header,['수량']),
      couponUsed: findCol(header,['쿠폰소진금액','쿠폰소진']),
      pointUsed:  findCol(header,['적립금소진금액','적립금소진']),
      payment:    findCol(header,['결제액']),
      couponSupport:findCol(header,['쿠폰지원금']),
      receiver:   findCol(header,['수취인명']),
      recPhone:   findCol(header,['수취인 연락처','수취인연락처']),
      phone:      findCol(header,['연락처']),
      address:    findCol(header,['배송지 주소','배송지주소']),
      memo:       findCol(header,['배송 메모','배송메모']),
      status:     findCol(header,['주문상태']),
      orderNum:   findCol(header,['상품주문번호']),
    };
  } else {
    idx={date:0,orderNum:1,name:4,option:7,price:5,qty:8,couponUsed:9,pointUsed:10,payment:11,couponSupport:12,receiver:17,recPhone:18,phone:15,address:20,memo:21,status:22};
  }
  const dataRows = (hasHeader?rows.slice(1):rows).filter(r=>r.length>5&&gc(r,idx.name));
  const orders = dataRows.map((r,i)=>({
    id:           Date.now()+i,
    date:         gc(r,idx.date),
    orderNum:     gc(r,idx.orderNum),
    productName:  gc(r,idx.name),
    option:       gc(r,idx.option),
    price:        pn(gc(r,idx.price)),
    qty:          Math.max(1,pn(gc(r,idx.qty))||1),
    couponUsed:   pn(gc(r,idx.couponUsed)),
    pointUsed:    pn(gc(r,idx.pointUsed)),
    payment:      pn(gc(r,idx.payment)),
    couponSupport:pn(gc(r,idx.couponSupport)),
    receiver:     gc(r,idx.receiver),
    phone:        gc(r,idx.recPhone)||gc(r,idx.phone),
    address:      gc(r,idx.address),
    memo:         gc(r,idx.memo),
    status:       gc(r,idx.status)||'상품 준비중',
  }));
  if(!orders.length){ document.getElementById('parseMsg').textContent='파싱된 데이터가 없습니다.'; return; }

  // ── 중복 제거: 기존 전체 주문번호 목록과 대조 ──
  const existingNums = new Set(allOrders().map(o=>o.orderNum).filter(Boolean));
  const newOrders  = orders.filter(o => !o.orderNum || !existingNums.has(o.orderNum));
  const skipCount  = orders.length - newOrders.length;
  if(!newOrders.length){
    document.getElementById('parseMsg').textContent=`⚠ 전체 ${orders.length}건이 이미 존재하는 데이터입니다. 중복 제외.`;
    return;
  }

  const batchName = document.getElementById('batchName').value.trim()||`업로드 ${new Date().toLocaleDateString('ko-KR')}`;
  batches.push({id:Date.now(), name:batchName, date:new Date().toLocaleString('ko-KR'), orders:newOrders});
  document.getElementById('batchName').value='';
  document.getElementById('pasteArea').value='';
  initCosts();
  updateDataStatus();
  scheduleSave();
  const msg = skipCount>0 ? `✓ ${newOrders.length}건 추가 (중복 ${skipCount}건 제외)` : `✓ ${newOrders.length}건 추가 완료`;
  document.getElementById('parseMsg').textContent=msg;
  closeModal();
  renderAll();
}

