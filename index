function renderProducts(){
  const orders=activeOrders(); if(!orders.length) return;
  const bp={};
  orders.forEach(o=>{ if(!bp[o.productName]) bp[o.productName]={pay:0,profit:0,cnt:0,qty:0}; bp[o.productName].pay+=o.payment; bp[o.productName].profit+=getProfit(o); bp[o.productName].cnt++; bp[o.productName].qty+=o.qty; });
  const byPay   =Object.entries(bp).sort((a,b)=>b[1].pay-a[1].pay);
  const byProfit=Object.entries(bp).sort((a,b)=>b[1].profit-a[1].profit);
  const maxPay   =byPay[0]?.[1]?.pay||1;
  const maxProfit=byProfit[0]?.[1]?.profit||1;
  function rankHTML(list,key,maxVal){
    return list.map(([name,v],i)=>{
      const val=v[key]; const pct=Math.round(val/maxVal*100);
      const margin=v.pay>0?v.profit/v.pay*100:0;
      return `<div class="rank-item">
        <div class="rank-num ${i<3?'top':''}">${i+1}</div>
        <div class="rank-info">
          <div class="rank-name" title="${name}">${name.slice(0,22)}</div>
          <div class="rank-meta">${v.cnt}건 · ${v.qty}개</div>
          <div class="bar-track"><div class="bar-fill ${key==='profit'?'g':''}" style="width:${pct}%"></div></div>
        </div>
        <div class="rank-values">
          <div class="rank-rev">${fmt(v.pay)}</div>
          <div class="rank-profit">${fmt(v.profit)}</div>
          <div class="rank-margin-pct">마진 ${fmtPct(margin)}</div>
        </div>
      </div>`;
    }).join('');
  }
  document.getElementById('productRank').innerHTML      =rankHTML(byPay,'pay',maxPay);
  document.getElementById('productProfitRank').innerHTML=rankHTML(byProfit,'profit',maxProfit);
}

