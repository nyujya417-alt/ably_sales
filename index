function applyBulkMargin(){
  const pct = Math.min(100,Math.max(0,parseFloat(document.getElementById('bulkMargin').value)||0));
  // 각 상품의 평균 결제가 기준으로 원가 역산
  const products = [...new Set(allOrders().map(o=>o.productName))];
  products.forEach(p=>{
    const orders = allOrders().filter(o=>o.productName===p);
    const avgPayPerUnit = orders.length>0
      ? orders.reduce((s,o)=>s+o.payment/o.qty,0)/orders.length : 0;
    const unitCost = avgPayPerUnit * (1 - pct/100);
    if(!costMap[p]) costMap[p]={costPrice:0,extraCost:0};
    costMap[p].costPrice = Math.round(unitCost);
    costMap[p].extraCost = 0;
  });
  renderMargin();
  scheduleSave();
}

