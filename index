  const el = document.getElementById('poGrid');
  if(!pending.length){
    el.innerHTML=`<div class="empty-state"><div class="empty-icon">🛒</div>발송 대기 주문이 없습니다<br>상품 준비중 상태의 주문이 있으면 자동으로 생성됩니다</div>`;
    ['po-items','po-qty','po-done','po-pending'].forEach(id=>document.getElementById(id).textContent='-');
    return;
  }

  // 상품 → 옵션 → { need:필요수량, orders[] }
  const map = {};
  pending.forEach(o=>{
    if(!map[o.productName]) map[o.productName]={};
    const opt = o.option||'없음';
    if(!map[o.productName][opt]) map[o.productName][opt]={need:0, orders:[]};
    map[o.productName][opt].need += o.qty;
    map[o.productName][opt].orders.push(o);
  });

  const allOptQtys = Object.values(map).flatMap(opts=>Object.values(opts).map(v=>v.need));
  const maxQty = Math.max(...allOptQtys, 1);
  const products = Object.keys(map).sort();

  let totalNeed=0, doneOpts=0, allOpts=0;

  const cards = products.map(p=>{
    const opts = Object.entries(map[p]).sort((a,b)=>b[1].need-a[1].need);
    const productNeed = opts.reduce((s,[,v])=>s+v.need, 0);
    totalNeed += productNeed;
    allOpts   += opts.length;

    const optRows = opts.map(([opt, data])=>{
      const k    = poKey(p, opt);
      const have = poQtyMap[k] ?? 0;
      const need = data.need;
      const done = have >= need;
      if(done) doneOpts++;
      const barW    = Math.min(100, Math.round(have/need*100));
      const barColor= done ? 'var(--green)' : have>0 ? 'var(--accent)' : 'var(--orange)';
      const refs    = data.orders.map(o=>o.receiver).slice(0,4);
      const safeP   = p.replace(/\\/g,'\\\\').replace(/'/g,"\\'");
      const safeO   = opt.replace(/\\/g,'\\\\').replace(/'/g,"\\'");

      return `<div class="po-option-row" style="${done?'opacity:0.6;':''}">
        <div style="flex:1;min-width:0;">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:5px;">
            <span class="po-opt-name" style="${done?'text-decoration:line-through;color:var(--text3);':''};font-size:13px;font-weight:500;">${opt}</span>
            <span style="font-size:11px;color:var(--text3);">필요 <strong style="color:var(--orange);">${need}개</strong></span>
            ${done?`<span class="badge badge-done" style="font-size:10px;">✓ 완료</span>`:''}
          </div>
          <!-- 수량 입력 -->
          <div style="display:flex;align-items:center;gap:8px;margin-bottom:5px;">
            <span style="font-size:11px;color:var(--text2);white-space:nowrap;">사입 수량</span>
            <div style="display:flex;align-items:center;gap:4px;">
              <button onclick="poAdjust('${safeP}','${safeO}',-1,${need})"
                style="width:26px;height:26px;border:1px solid var(--border2);border-radius:5px;background:var(--bg3);cursor:pointer;font-size:14px;line-height:1;color:var(--text2);">−</button>
              <input type="number" min="0" max="${need*3}" value="${have}"
                style="width:56px;text-align:center;font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:600;padding:4px 6px;border:1px solid ${done?'var(--green)':'var(--border2)'};border-radius:5px;color:${done?'var(--green)':'var(--text)'};"
                oninput="poSetQty('${safeP}','${safeO}',this.value,${need})"
                onclick="this.select()">
              <button onclick="poAdjust('${safeP}','${safeO}',1,${need})"
                style="width:26px;height:26px;border:1px solid var(--border2);border-radius:5px;background:var(--bg3);cursor:pointer;font-size:14px;line-height:1;color:var(--text2);">+</button>
              <button onclick="poSetQty('${safeP}','${safeO}',${need},${need})"
                style="padding:4px 8px;border:1px solid rgba(22,163,74,0.3);border-radius:5px;background:rgba(22,163,74,0.08);cursor:pointer;font-size:11px;color:var(--green);white-space:nowrap;">전량(${need})</button>
            </div>
            <span style="font-size:11px;color:${done?'var(--green)':have>0?'var(--accent)':'var(--text3)'};">${have}/${need}</span>
          </div>
          <!-- 진행 바 -->
          <div class="po-opt-bar"><div style="height:100%;border-radius:99px;background:${barColor};width:${barW}%;transition:width 0.3s;"></div></div>
          <div style="font-size:10px;color:var(--text3);margin-top:4px;">${refs.join(' · ')}${data.orders.length>4?' 외 '+(data.orders.length-4)+'명':''}</div>
        </div>
      </div>`;
    }).join('');

    const productDone = opts.every(([opt])=>{ const k=poKey(p,opt); return (poQtyMap[k]??0)>=map[p][opt].need; });

    return `<div class="po-card ${productDone?'po-done':''}">
      <div class="po-card-header">
        <div style="flex:1;">
          <div style="display:flex;align-items:center;gap:8px;flex-wrap:wrap;">
            <div class="po-product-name">${p}</div>
            ${productDone?`<span class="badge badge-done">✓ 발주완료</span>`:''}
          </div>
          <div style="font-size:11px;color:var(--text3);margin-top:2px;">총 필요 ${productNeed}개 · ${opts.length}가지 옵션</div>
        </div>
        <span class="po-total-badge" style="background:${productDone?'var(--green)':'var(--orange)'};">${productNeed}개</span>
      </div>
      <div class="po-option-list">${optRows}</div>
    </div>`;
  }).join('');

  el.innerHTML = cards;

  // 요약
  document.getElementById('po-items').textContent   = products.length+'종';
  document.getElementById('po-qty').textContent     = totalNeed+'개';
  document.getElementById('po-done').textContent    = doneOpts+'/'+allOpts;
  document.getElementById('po-pending').textContent = (allOpts-doneOpts)+'개';
}

function poSetQty(productName, option, val, need){
  const k = poKey(productName, option);
  const v = Math.max(0, Math.min(need*3, parseInt(val)||0));
  poQtyMap[k] = v;
  scheduleSave();
  renderOrderMgmt();
}
function poAdjust(productName, option, delta, need){
  const k = poKey(productName, option);
  const cur = poQtyMap[k] ?? 0;
  poQtyMap[k] = Math.max(0, Math.min(need*3, cur+delta));
  scheduleSave();
  renderOrderMgmt();
}

function poCheckAll(){
  const pending = activeOrders().filter(o=>o.status==='상품 준비중');
  const map={};
  pending.forEach(o=>{
    const opt=o.option||'없음'; const k=poKey(o.productName,opt);
    map[k]=(map[k]||0)+o.qty;
  });
  Object.entries(map).forEach(([k,need])=>{ poQtyMap[k]=need; });
  scheduleSave(); renderOrderMgmt();
}
function poUncheckAll(){ poQtyMap={}; scheduleSave(); renderOrderMgmt(); }

function copyOrderList(){
  const pending = activeOrders().filter(o=>o.status==='상품 준비중');
  if(!pending.length){ alert('발주할 항목이 없어!'); return; }
  const map={};
  pending.forEach(o=>{
    if(!map[o.productName]) map[o.productName]={};
    const opt=o.option||'없음';
    if(!map[o.productName][opt]) map[o.productName][opt]=0;
    map[o.productName][opt]+=o.qty;
  });
  const lines = Object.entries(map).map(([p,opts],i)=>{
    const optLines = Object.entries(opts).sort((a,b)=>b[1]-a[1]).map(([opt,need])=>{
      const k=poKey(p,opt); const have=poQtyMap[k]??0;
      const status = have>=need ? '[완료]' : have>0 ? `[진행중 ${have}/${need}]` : '[미발주]';
      return `  · ${status} ${opt}: ${need}개`;
    }).join('\n');
    const total=Object.values(opts).reduce((s,v)=>s+v,0);
    return `[${i+1}] ${p} (총 ${total}개)\n${optLines}`;
  }).join('\n\n');
  const header=`== 발주 목록 (${new Date().toLocaleDateString('ko-KR')}) ==\n총 ${Object.keys(map).length}종\n${'─'.repeat(36)}\n\n`;
  navigator.clipboard.writeText(header+lines).then(()=>showPoToast()).catch(()=>{
    const ta=document.createElement('textarea'); ta.value=header+lines;
    ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
    document.body.removeChild(ta); showPoToast();
  });
}
function showPoToast(){
  const t=document.getElementById('poCopyToast');
  t.style.display='block';
  setTimeout(()=>{ t.style.display='none'; },3500);
}

// ═══════════════════════════════════════
//  엑셀 다운로드 (파슬미디어/CJ대한통운 양식)
// ═══════════════════════════════════════
function exportExcel(){
  const checkedShipping = activeOrders().filter(o=>o.status==='배송중' && checkedIds[o.id]);
  const pending         = activeOrders().filter(o=>o.status==='상품 준비중');
  const items           = [...pending, ...checkedShipping];
  if(!items.length){ alert('발송 목록이 없어!'); return; }

  // 이미지 양식 컬럼 순서 그대로
  const HEADERS = [
    '순번','이름','핸드폰번호','연락처','우편번호',
    '주소','상세주소','배송상품성보','물품명','제품단가','요청사항'
  ];

  const esc = s => String(s??'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');

  const dataRows = items.map((o, i) => {
    const fullAddr = o.address || '';

    // 주소 분리 — 도로명주소(~번지/~호) + 나머지(동호수 등)
    const m = fullAddr.match(/^([\s\S]*?(?:\d+(?:-\d+)?(?:길|로|대로)\s+\d+))(\s*[\s\S]*)$/);
    const mainAddr   = m ? m[1].trim() : fullAddr;
    const detailAddr = m && m[2].trim() ? m[2].trim() : '';

    const s         = shippingMap[o.productName] || {};
    const itemName  = s.itemName  || '기타';
    const unitPrice = s.unitPrice != null ? s.unitPrice : 50000;

    return [
      i + 1,
      o.receiver,
      o.phone,
      '',                // 연락처 (수취인 2번째 번호, 보통 공란)
      o.zip || '',
      mainAddr,
      detailAddr,
      'B',               // 배송상품성보 기본값
      itemName,
      unitPrice,
      o.memo || '',
    ];
  });

  // HTML Table XLS — Excel에서 제대로 열리고 한글 안 깨짐
  const thStyle = 'background:#FFF176;font-weight:bold;border:1px solid #ccc;padding:4px 8px;font-size:11pt;white-space:nowrap;';
  const tdStyle = 'border:1px solid #ddd;padding:4px 8px;font-size:10.5pt;';
  const tdNumStyle = 'border:1px solid #ddd;padding:4px 8px;font-size:10.5pt;text-align:right;mso-number-format:General;';

  const headerRow = HEADERS.map(h=>`<th style="${thStyle}">${esc(h)}</th>`).join('');
  const bodyRows  = dataRows.map(row =>
    '<tr>' + row.map((cell, ci) => {
      const isNum = typeof cell === 'number' || (ci===9); // 제품단가 숫자
      return isNum
        ? `<td style="${tdNumStyle}" x:num>${esc(cell)}</td>`
        : `<td style="${tdStyle}">${esc(cell)}</td>`;
    }).join('') + '</tr>'
  ).join('\n');

  const html = `<?xml version="1.0" encoding="UTF-8"?>
<?mso-application progid="Excel.Sheet"?>
<Workbook xmlns="urn:schemas-microsoft-com:office:spreadsheet"
  xmlns:ss="urn:schemas-microsoft-com:office:spreadsheet"
  xmlns:x="urn:schemas-microsoft-com:office:excel">
  <Worksheet ss:Name="발송목록">
    <Table>
      <Row>${HEADERS.map(h=>`<Cell><Data ss:Type="String">${esc(h)}</Data></Cell>`).join('')}</Row>
      ${dataRows.map(row=>`<Row>${row.map((cell,ci)=>{
        const t = (typeof cell==='number'||ci===9) ? 'Number' : 'String';
        return `<Cell><Data ss:Type="${t}">${esc(cell)}</Data></Cell>`;
      }).join('')}</Row>`).join('\n      ')}
    </Table>
  </Worksheet>
</Workbook>`;

  const bom  = '\uFEFF';
  const blob = new Blob([bom + html], { type: 'application/vnd.ms-excel;charset=utf-8' });
  const url  = URL.createObjectURL(blob);
  const a    = document.createElement('a');
  const date = new Date().toLocaleDateString('ko-KR').replace(/\. /g,'-').replace('.','').trim();
  a.href     = url;
  a.download = `발송목록_${date}.xls`;
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);

  const t = document.getElementById('excelToast');
  t.style.display='block';
  setTimeout(()=>{ t.style.display='none'; }, 3500);
}

function clearAllBatches(){
  if(!batches.length) return;
  if(!confirm(`전체 ${batches.length}개 배치, ${allOrders().length}건을 모두 삭제할까요?`)) return;
  batches=[]; costMap={}; checkedIds={}; poCheckedIds={}; poQtyMap={};
  updateDataStatus(); scheduleSave(); renderAll();
}

// ═══════════════════════════════════════
//  INIT — localStorage에서 복원
// ═══════════════════════════════════════
window.addEventListener('DOMContentLoaded', ()=>{
  const restored = loadFromStorage();
  if(restored){
    updateDataStatus();
    renderAll();
    document.getElementById('saveIndicator').textContent = '저장된 데이터 복원됨 ✓';
    document.getElementById('saveIndicator').className = 'save-indicator saving';
    setTimeout(()=>{
      document.getElementById('saveIndicator').textContent='자동 저장됨';
      document.getElementById('saveIndicator').className='save-indicator';
    }, 3000);
  }
});
</script>
