  allOrders().forEach(o=>{
    if(!costMap[o.productName])    costMap[o.productName]    = {costPrice:0, extraCost:0};
    if(!shippingMap[o.productName]) shippingMap[o.productName] = {itemName:'', unitPrice:50000};
  });
}

// 주문 1건의 순이익 계산
// 순이익 = 결제액 - (매입가 + 기타비용) × 수량
function getProfit(o){
  const c = costMap[o.productName]||{costPrice:0,extraCost:0};
  return o.payment - (c.costPrice + c.extraCost) * o.qty;
}
// 마진율 = 순이익 / 결제액 × 100
function getMarginPct(o){
  if(o.payment<=0) return 0;
  return getProfit(o)/o.payment*100;
}

