function toggleCheck(id){
  const order = allOrders().find(o=>o.id===id);
  if(!order) return;
  const nowChecked = !checkedIds[id];
  checkedIds[id] = nowChecked;
  // 체크 → 배송중, 체크 해제 → 상품 준비중으로 복원
  if(nowChecked && order.status==='상품 준비중') order.status='배송중';
  else if(!nowChecked && order.status==='배송중') order.status='상품 준비중';
  scheduleSave(); renderAll();
}
function checkAll(){
  activeOrders().filter(o=>o.status==='상품 준비중').forEach(o=>{
    checkedIds[o.id]=true; o.status='배송중';
  });
  scheduleSave(); renderAll();
}
function uncheckAll(){
  // 배송중 중 checkedIds에 있던 것만 상품 준비중으로 복원
  allOrders().forEach(o=>{ if(checkedIds[o.id] && o.status==='배송중') o.status='상품 준비중'; });
  checkedIds={};
  scheduleSave(); renderAll();
}

