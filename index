function copyChecklist(){
  const checkedShipping = activeOrders().filter(o=>o.status==='배송중' && checkedIds[o.id]);
  const pending = activeOrders().filter(o=>o.status==='상품 준비중');
  const allItems = [...pending, ...checkedShipping];
  if(!allItems.length){ alert('복사할 항목이 없어!'); return; }

  const lines = allItems.map((o,i)=>{
    const status = checkedIds[o.id] ? '[배송중]' : '[발송대기]';
    return [
      `[${i+1}] ${status} ${o.productName}${o.option?' / '+o.option:''}`,
      `  수취인: ${o.receiver}`,
      `  전화번호: ${o.phone}`,
      o.address ? `  주소: ${o.address}` : '',
      o.memo    ? `  배송메모: ${o.memo}` : '',
      `  수량: ${o.qty}개 | 결제액: ${fmt(o.payment)} | 주문일: ${o.date}`,
    ].filter(Boolean).join('\n');
  }).join('\n\n');

  const header = `== 발송 체크리스트 (${new Date().toLocaleDateString('ko-KR')}) ==\n총 ${allItems.length}건 (발송대기 ${pending.length}건 / 배송중 ${checkedShipping.length}건)\n${'─'.repeat(40)}\n\n`;

  navigator.clipboard.writeText(header+lines).then(()=>{
    const t = document.getElementById('copyToast');
    t.style.display='block';
    setTimeout(()=>{ t.style.display='none'; }, 3500);
  }).catch(()=>{
    // fallback
    const ta = document.createElement('textarea');
    ta.value = header+lines; ta.style.position='fixed'; ta.style.opacity='0';
    document.body.appendChild(ta); ta.select(); document.execCommand('copy');
    document.body.removeChild(ta);
    const t = document.getElementById('copyToast');
    t.style.display='block';
    setTimeout(()=>{ t.style.display='none'; }, 3500);
  });
}

