function renderOrders(){
  const df=document.getElementById('dateFrom').value;
  const dt=document.getElementById('dateTo').value;
  const sf=document.getElementById('statusFilter').value;
  const q=(document.getElementById('searchInput').value||'').toLowerCase();
  const filtered=allOrders().filter(o=>{
    if(df&&o.date<df) return false;
    if(dt&&o.date>dt) return false;
    if(sf&&o.status!==sf) return false;
    if(q&&!o.productName.toLowerCase().includes(q)&&!o.receiver.toLowerCase().includes(q)) return false;
    return true;
  });
  const STATUS_OPTIONS = ['상품 준비중','배송중','구매 확정','배송 완료','취소 완료','반품 접수','반품 완료'];
  const tb=document.getElementById('ordersBody');
  if(!filtered.length){ tb.innerHTML=`<tr><td colspan="12"><div class="empty-state"><div class="empty-icon">🔍</div>검색 결과 없음</div></td></tr>`; return; }
  tb.innerHTML=filtered.map(o=>{
    const isExcluded = EXCLUDED.has(o.status);
    const profit = isExcluded ? null : getProfit(o);
    const pColor = profit===null?'var(--text3)':profit>=0?'var(--green)':'var(--red)';
    const rowStyle = isExcluded ? 'opacity:0.45;background:var(--bg3);' : '';
    const opts = STATUS_OPTIONS.map(s=>`<option value="${s}" ${o.status===s?'selected':''}>${s}</option>`).join('');
    return `<tr style="${rowStyle}">
      <td class="mono">${o.date.slice(5)}</td>
      <td title="${o.productName}">${o.productName.slice(0,14)}</td>
      <td title="${o.option}">${(o.option||'').slice(0,10)}</td>
      <td>${o.qty}</td>
      <td class="mono" style="${isExcluded?'text-decoration:line-through;color:var(--text3);':''}">${fmt(o.price*o.qty)}</td>
      <td class="mono" style="color:var(--text3);">-${fmt(o.couponUsed)}</td>
      <td class="mono" style="color:var(--text3);">-${fmt(o.pointUsed)}</td>
      <td class="mono" style="color:${isExcluded?'var(--text3)':'var(--purple)'};font-weight:500;${isExcluded?'text-decoration:line-through;':''}">${fmt(o.payment)}</td>
      <td class="mono" style="color:${pColor};font-weight:500;">${isExcluded?'제외':fmt(profit)}</td>
      <td>${o.receiver}</td>
      <td>
        <select style="font-size:11px;padding:3px 6px;border-radius:5px;border:1px solid var(--border);background:var(--bg2);color:var(--text);cursor:pointer;"
          onchange="changeStatus(${o.id},this.value)">${opts}</select>
      </td>
      <td><button class="btn-icon" onclick="deleteOrder(${o.id})" title="삭제">✕</button></td>
    </tr>`;
  }).join('');
  const activeCount = filtered.filter(o=>!EXCLUDED.has(o.status)).length;
  const exCount = filtered.length - activeCount;
  document.getElementById('orderCount').textContent=`${filtered.length}건 표시 (매출 집계: ${activeCount}건, 제외: ${exCount}건)`;
}

function deleteOrder(id){
  if(!confirm('이 주문을 삭제할까요?')) return;
  batches.forEach(b=>{ b.orders=b.orders.filter(o=>o.id!==id); });
  batches=batches.filter(b=>b.orders.length>0);
  updateDataStatus(); scheduleSave(); renderAll();
}

function changeStatus(id, newStatus){
  allOrders().forEach(o=>{ if(o.id===id) o.status=newStatus; });
  scheduleSave(); renderAll();
}

